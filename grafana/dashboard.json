      "targets": [
        {
          "format": "time_series",
          "rawSql": "WITH src AS (\n  SELECT\n    TIMESTAMP_TRUNC(timestamp, MINUTE) AS time,\n    COALESCE(resource.labels.namespace_name, 'unknown') AS namespace,\n    IF(severity IN ('ERROR','CRITICAL','ALERT','EMERGENCY') OR logName LIKE '%stderr%', 1, 0) AS is_error\n  FROM `${project}.${dataset}.stderr_*`\n  WHERE _TABLE_SUFFIX BETWEEN FORMAT_DATE('%Y%m%d', DATE(TIMESTAMP_MILLIS($__from)))\n    AND FORMAT_DATE('%Y%m%d', DATE(TIMESTAMP_MILLIS($__to)))\n)\nSELECT\n  time,\n  namespace AS metric,\n  SAFE_DIVIDE(SUM(is_error), COUNT(1)) * 100 AS value\nFROM src\nGROUP BY time, metric\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Application Error Rate by Namespace (%)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "${DS_BQ}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT\n  TIMESTAMP_TRUNC(timestamp, MINUTE) AS time,\n  COALESCE(resource.labels.namespace_name, 'unknown') AS metric,\n  COUNT(1) AS value\nFROM `${project}.${dataset}.events_*`\nWHERE _TABLE_SUFFIX BETWEEN FORMAT_DATE('%Y%m%d', DATE(TIMESTAMP_MILLIS($__from)))\n  AND FORMAT_DATE('%Y%m%d', DATE(TIMESTAMP_MILLIS($__to)))\n  AND COALESCE(jsonPayload.reason, '') IN ('BackOff','Killing','Started','Unhealthy')\nGROUP BY time, metric\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Pod Restart/Instability Events by Namespace",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "${DS_BQ}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "WITH latency AS (\n  SELECT\n    TIMESTAMP_TRUNC(timestamp, MINUTE) AS time,\n    CAST(JSON_VALUE(httpRequest, '$.latency') AS STRING) AS latency_str\n  FROM `${project}.${dataset}.requests_*`\n  WHERE _TABLE_SUFFIX BETWEEN FORMAT_DATE('%Y%m%d', DATE(TIMESTAMP_MILLIS($__from)))\n    AND FORMAT_DATE('%Y%m%d', DATE(TIMESTAMP_MILLIS($__to)))\n), parsed AS (\n  SELECT\n    time,\n    SAFE_CAST(REGEXP_REPLACE(latency_str, r's$', '') AS FLOAT64) * 1000 AS latency_ms\n  FROM latency\n  WHERE latency_str IS NOT NULL\n), q AS (\n  SELECT\n    time,\n    APPROX_QUANTILES(latency_ms, 100) AS p\n  FROM parsed\n  GROUP BY time\n)\nSELECT time, 'p50' AS metric, p[OFFSET(50)] AS value FROM q\nUNION ALL\nSELECT time, 'p95' AS metric, p[OFFSET(95)] AS value FROM q\nUNION ALL\nSELECT time, 'p99' AS metric, p[OFFSET(99)] AS value FROM q\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Request Latency p50/p95/p99 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "${DS_BQ}"
