        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT\n  TIMESTAMP_TRUNC(timestamp, MINUTE) AS time,\n  CASE\n    WHEN logName LIKE '%stdout%' THEN 'stdout_lines'\n    WHEN logName LIKE '%stderr%' THEN 'stderr_lines'\n    ELSE 'events'\n  END AS metric,\n  COUNT(1) AS value\nFROM `${project}.${dataset}.events_*`\nWHERE _TABLE_SUFFIX BETWEEN FORMAT_DATE('%Y%m%d', DATE(TIMESTAMP_MILLIS($__from)))\n  AND FORMAT_DATE('%Y%m%d', DATE(TIMESTAMP_MILLIS($__to)))\nGROUP BY time, metric\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Resource/Activity Utilization Trend (log activity proxy)",
      "type": "timeseries"
    }
